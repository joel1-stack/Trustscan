# === Required (set these in Northflank Service > Environment) ===
SECRET_KEY=generate-a-random-long-secret-key
DJANGO_SETTINGS_MODULE=config.settings
DEBUG=False
NORTHFLANK=True
ALLOWED_HOSTS=.northflank.app,.onrender.com,trustscan.co.ke
CSRF_TRUSTED_ORIGINS=https://my-app-1234.northflank.app,https://trustscan.co.ke
CORS_ALLOWED_ORIGINS=https://my-app-1234.northflank.app,https://trustscan.co.ke

# Database (Northflank will inject these via addon binding)
DB_ENGINE=django.db.backends.postgresql
# DB_NAME, DB_USER, DB_PASSWORD, DB_HOST, DB_PORT are auto-injected by Northflank

# Redis (auto-injected by Northflank addon binding)
REDIS_URL=redis://...
CELERY_BROKER_URL=redis://...
CELERY_RESULT_BACKEND=redis://...

# Email (for magic link and verification)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=TrustScan <noreply@trustscan.co.ke>

# Optional API keys (leave empty to skip those engines)
SHODAN_API_KEY=
HIBP_API_KEY=
VIRUSTOTAL_API_KEY=
