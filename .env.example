# Sentry
SENTRY_DSN=

# TrustScan Settings
TRUSTSCAN_SCAN_TIMEOUT=300
TRUSTSCAN_MAX_SUBDOMAINS=500
TRUSTSCAN_RATE_LIMIT_PER_HOUR=10

# Tax
TAX_RATE=0.16