# Django Settings
SECRET_KEY=your-secret-key-here-generate-with-django-secret-key-generator
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,trustscan.co.ke,api.trustscan.co.ke

# Database
DATABASE_URL=sqlite:///db.sqlite3
# For PostgreSQL: postgresql://user:password@localhost:5432/trustscan

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=TrustScan <noreply@trustscan.co.ke>

# Frontend URL
FRONTEND_URL=http://localhost:3000

# External API Keys
SHODAN_API_KEY=
CENSYS_API_ID=
CENSYS_API_SECRET=
HIBP_API_KEY=
DEHASHED_API_KEY=
VIRUSTOTAL_API_KEY=
GOOGLE_SAFE_BROWSING_API_KEY=
SPAMHAUS_API_KEY=
ABUSEIPDB_API_KEY=
GITHUB_TOKEN=
BUILTWITH_API_KEY=
SECURITYTRAILS_API_KEY=

# M-Pesa Daraja API
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://api.trustscan.co.ke/api/v1/billing/mpesa/callback/
