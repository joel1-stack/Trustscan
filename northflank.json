{
  "project": "trustscan",
  "services": [
    {
      "name": "web",
      "type": "docker",
      "build": {
        "dockerfile": "Dockerfile",
        "context": "."
      },
      "ports": [
        {
          "port": 8080,
          "protocol": "http"
        }
      ],
      "env": {
        "DJANGO_SETTINGS_MODULE": "config.settings",
        "DEBUG": "False",
        "NORTHFLANK": "True",
        "DB_ENGINE": "django.db.backends.postgresql"
      },
      "resources": {
        "cpu": 1,
        "memory": "1Gi"
      }
    },
    {
      "name": "celery-worker",
      "type": "docker",
      "build": {
        "dockerfile": "Dockerfile.worker",
        "context": "."
      },
      "env": {
        "DJANGO_SETTINGS_MODULE": "config.settings",
        "DEBUG": "False",
        "NORTHFLANK": "True",
        "DB_ENGINE": "django.db.backends.postgresql",
        "CELERY_BROKER_URL": "redis://redis:6379/0",
        "CELERY_RESULT_BACKEND": "redis://redis:6379/1"
      },
      "resources": {
        "cpu": 1,
        "memory": "1Gi"
      }
    }
  ],
  "addons": [
    {
      "type": "postgresql",
      "version": "16",
      "name": "trustscan-db"
    },
    {
      "type": "redis",
      "version": "7",
      "name": "trustscan-redis"
    }
  ]
}
